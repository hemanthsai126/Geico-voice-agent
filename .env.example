NODE_ENV=development
PORT=3000

# Public HTTPS URL for Twilio webhooks. Browser microphone testing can use localhost.
PUBLIC_BASE_URL=https://your-public-domain.example

OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_REALTIME_MODEL=gpt-realtime-2

# Voice-model A/B testing: set provider and paste keys only into your local .env (never commit .env).
VOICE_MODEL_PROVIDER=openai
GROK_API_KEY=xai-your-xai-api-key
GROK_VOICE_MODEL=grok-voice-think-fast-1.0
GEMINI_API_KEY=your-google-gemini-api-key
GEMINI_VOICE_MODEL=gemini-3.1-flash-live-preview

FIREBASE_PROJECT_ID=your-firebase-project-id
FIRESTORE_COLLECTION=voiceIntakeLeads

# Optional for local service-account auth. If omitted, Application Default Credentials are used.
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@example.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
