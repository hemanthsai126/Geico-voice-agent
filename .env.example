NODE_ENV=development
PORT=3000

# Base URL Twilio uses for `/twilio/voice` Stream WebSocket (defaults to http://127.0.0.1:PORT if unset). Set to your https tunnel for real phone tests.
# PUBLIC_BASE_URL=https://your-tunnel.example.com

OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_REALTIME_MODEL=gpt-realtime-2

# Default voice provider for the demo when the picker is unchanged: openai | grok | gemini
VOICE_MODEL_PROVIDER=openai
GROK_API_KEY=xai-your-xai-api-key
GROK_VOICE_MODEL=grok-voice-think-fast-1.0
GEMINI_API_KEY=your-google-gemini-api-key
GEMINI_VOICE_MODEL=gemini-3.1-flash-live-preview

# Default opening when the browser omits ?mode=. Demo pages (/inbound, /outbound) send ?mode= explicitly.
CALL_MODE=inbound

FIREBASE_PROJECT_ID=your-firebase-project-id
FIRESTORE_COLLECTION=voiceIntakeLeads

# Optional for local service-account auth. If omitted, Application Default Credentials are used.
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@example.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
