{
  "name": "voice-agent",
  "version": "1.0.0",
  "description": "Voice intake agent using OpenAI Realtime, browser microphone, and Firebase.",
  "type": "module",
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
